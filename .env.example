# ══ Vertex AI — Gemini Vision ═════════════════════════════════
# เลือกอย่างใดอย่างหนึ่ง:

# Option A (แนะนำสำหรับ local dev): path ไปยังไฟล์ service account JSON
VERTEX_SA_JSON_PATH=/path/to/service-account.json

# Option B (แนะนำสำหรับ Docker/K8s): JSON string ทั้งก้อนใส่ใน secret
# VERTEX_SA_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Google Cloud Project ID (จาก GCP Console)
VERTEX_PROJECT=my-gcp-project-id

# Region — us-central1 หรือ asia-southeast1 (ใกล้ไทยกว่า)
VERTEX_LOCATION=us-central1

# ══ Google Maps Static API ════════════════════════════════════
# เปิดใช้ "Maps Static API" ที่ https://console.cloud.google.com
GOOGLE_MAPS_KEY=XXxx...


# ══ CORS (optional) ═══════════════════════════════════════════
# เปิด * สำหรับ dev เมื่อเปิด HTML ตรงจาก file:// หรือ port อื่น
# อย่าใช้ใน production!
CORS_ALLOW_ALL=true